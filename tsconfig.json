{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "types": [
      "node",
      "vscode"
    ]
  },
  "include": [
    "src",
    "test"
  ],
  "exclude": [
    "test/e2e",
    "test/unit/themeDetection.property.test.ts",
    "test/unit/themeObserver.test.ts",
    "test/unit/findSourceLine.property.test.ts",
    "test/unit/messageHandler.test.ts",
    "test/unit/previewInitResilience.property.test.ts",
    "test/unit/loadingOverlay.test.ts",
    "test/unit/loadingOverlayMessageHandler.test.ts",
    "test/unit/initialLoadSpinner.test.ts",
    "test/unit/demoVscodeLauncher.test.ts",
    "test/unit/zoomPanController.property.test.ts"
  ]
}
